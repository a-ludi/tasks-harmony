{
  "name": "tasks-harmony",
  "version": "0.9.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "generate-icons": "rsvg-convert -w 192 -h 192 icon-template.svg -o public/icon-192.png && rsvg-convert -w 512 -h 512 icon-template.svg -o public/icon-512.png",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "bun test --isolate src/",
    "test:e2e": "bunx playwright test",
    "typecheck": "tsc --noEmit",
    "generate-changelog": "bun run scripts/generate-changelog.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "^0.9.9",
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "lefthook": "^2.1.9",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@milkdown/core": "^7.21.2",
    "@milkdown/plugin-block": "^7.21.2",
    "@milkdown/plugin-emoji": "^7.21.2",
    "@milkdown/plugin-history": "^7.21.2",
    "@milkdown/plugin-indent": "^7.21.2",
    "@milkdown/plugin-listener": "^7.21.2",
    "@milkdown/preset-commonmark": "^7.21.2",
    "@milkdown/preset-gfm": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "js-yaml": "^4.2.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "transliteration": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "webdav": "^5.10.0",
    "zustand": "^5.0.14"
  }
